<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="add-event-date-locations-composite-index" author="Shankin">
        <createIndex tableName="events_dates_locations"
                     indexName="idx_event_date_locations_event_start">
            <column name="event_id"/>
            <column name="start_date"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="events_dates_locations"
                       indexName="idx_events_dates_locations_event_start"/>
        </rollback>
    </changeSet>

    <changeSet id="add-events-dates-locations-finish-date-index" author="Shankin">
        <createIndex tableName="events_dates_locations"
                     indexName="idx_events_dates_locations_finish_date">
            <column name="finish_date"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="events_dates_locations"
                       indexName="idx_event_date_locations_finish_date"/>
        </rollback>
    </changeSet>

</databaseChangeLog>