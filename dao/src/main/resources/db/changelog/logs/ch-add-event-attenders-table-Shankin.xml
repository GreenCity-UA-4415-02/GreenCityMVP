<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <!-- Events attenders table -->
    <changeSet id="create-events-attenders-table" author="Shankin">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="events_attenders"/>
            </not>
        </preConditions>

        <createTable tableName="events_attenders">
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Primary key constraint -->
        <addPrimaryKey tableName="events_attenders"
                       columnNames="event_id, user_id"
                       constraintName="PK_events_attenders"/>

        <!-- Foreign key constraints -->
        <addForeignKeyConstraint baseColumnNames="event_id"
                                 baseTableName="events_attenders"
                                 constraintName="FK_events_attenders_event_id"
                                 referencedColumnNames="id"
                                 referencedTableName="events"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="events_attenders"
                                 constraintName="FK_events_attenders_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"
                                 onDelete="CASCADE"/>

        <!-- Indexes for performance -->
        <createIndex tableName="events_attenders" indexName="idx_events_attenders_event_id">
            <column name="event_id"/>
        </createIndex>
        <createIndex tableName="events_attenders" indexName="idx_events_attenders_user_id">
            <column name="user_id"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="events_attenders" indexName="idx_events_attenders_user_id"/>
            <dropIndex tableName="events_attenders" indexName="idx_events_attenders_event_id"/>
            <dropForeignKeyConstraint baseTableName="events_attenders" constraintName="FK_events_attenders_user_id"/>
            <dropForeignKeyConstraint baseTableName="events_attenders" constraintName="FK_events_attenders_event_id"/>
            <dropPrimaryKey tableName="events_attenders" constraintName="PK_events_attenders"/>
            <dropTable tableName="events_attenders" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <!-- Add default values for created_at columns -->
    <changeSet id="add-default-values-for-timestamps" author="Shankin">
        <sql>
            ALTER TABLE events_attenders ALTER COLUMN created_at SET DEFAULT CURRENT_TIMESTAMP;
        </sql>

        <rollback>
            <sql>
                ALTER TABLE events_attenders ALTER COLUMN created_at DROP DEFAULT;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
