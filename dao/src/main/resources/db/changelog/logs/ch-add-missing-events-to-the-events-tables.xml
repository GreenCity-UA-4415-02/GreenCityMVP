<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="create-events-table" author="DianaDubenok">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="events"/>
            </not>
        </preConditions>
        <createTable tableName="events">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(70)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="is_open" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="create-events-dates-table" author="DianaDubenok">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="events_dates_locations"/>
            </not>
        </preConditions>
        <createTable tableName="events_dates_locations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="finish_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="latitude" type="DECIMAL(10,7)"/>
            <column name="longitude" type="DECIMAL(10,7)"/>
            <column name="online_link" type="VARCHAR(255)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="events_dates_locations"
                                 baseColumnNames="event_id"
                                 referencedTableName="events"
                                 referencedColumnNames="id"
                                 constraintName="fk_events_dates_event"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="create-events-images-table" author="DianaDubenok">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="events_images"/>
            </not>
        </preConditions>
        <createTable tableName="events_images">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="image_path" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="is_main" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="events_images"
                                 baseColumnNames="event_id"
                                 referencedTableName="events"
                                 referencedColumnNames="id"
                                 constraintName="fk_events_images_event"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="create-events-tags-table" author="DianaDubenok">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="events_tags"/>
            </not>
        </preConditions>
        <createTable tableName="events_tags">
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="tag_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="events_tags"
                                 baseColumnNames="event_id"
                                 referencedTableName="events"
                                 referencedColumnNames="id"
                                 constraintName="fk_events_tags_event"
                                 onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="events_tags"
                                 baseColumnNames="tag_id"
                                 referencedTableName="tags"
                                 referencedColumnNames="id"
                                 constraintName="fk_events_tags_tag"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="indexes" author="DianaDubenok">
        <createIndex indexName="idx_events_dates_event_id" tableName="events_dates_locations">
            <column name="event_id"/>
        </createIndex>
        <createIndex indexName="idx_events_images_event_id" tableName="events_images">
            <column name="event_id"/>
        </createIndex>
        <createIndex indexName="idx_events_tags_event_id" tableName="events_tags">
            <column name="event_id"/>
        </createIndex>
        <createIndex indexName="idx_events_tags_tag_id" tableName="events_tags">
            <column name="tag_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
