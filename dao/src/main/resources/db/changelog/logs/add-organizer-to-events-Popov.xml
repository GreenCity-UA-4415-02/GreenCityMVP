<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="add-organizer-to-events-Popov" author="Ivan Popov">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="events" columnName="organizer_id"/>
            </not>
        </preConditions>

        <addColumn tableName="events">
            <column name="organizer_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
                baseTableName="events"
                baseColumnNames="organizer_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_events_organizer_user"
                onDelete="SET NULL"/>
    </changeSet>

</databaseChangeLog>
