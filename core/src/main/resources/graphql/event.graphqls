type Event {
    id: ID!
    title: String!
    description: String
    isOpen: Boolean
    createdAt: String
    updatedAt: String
}

type Query {
    getAllEvents: [Event]
}


type Mutation {
    _emptyEventMutation: Boolean
}


type EventUpdatePayload {
    id: ID!
    title: String!
    eventType: EventActionType!
}

enum EventActionType {
    CREATED
    EDITED
    DELETED
}

type Subscription {
    eventUpdates: EventUpdatePayload
}